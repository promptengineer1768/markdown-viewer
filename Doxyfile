PROJECT_NAME           = "markdown-viewer"
PROJECT_BRIEF          = "Markdown viewer app and markdown_core library"
OUTPUT_DIRECTORY       = docs/generated
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
INPUT                  = include src/core docs/API.md README.md
FILE_PATTERNS          = *.h *.cc *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */debug/* */tests/*
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
STRIP_FROM_PATH        = .
